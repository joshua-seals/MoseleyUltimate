[Unit]
Description=Moseley Ultimate App
After=network.target

[Service]
ExecStart=/opt/moseleyultimate/moseleyultimate
WorkingDirectory=/opt/moseleyultimate
Restart=always
RestartSec=5
User=frisbeeUser
Environment=ENV=production
EnvironmentFile=/opt/moseleyultimate/.env

[Install]
WantedBy=multi-user.target